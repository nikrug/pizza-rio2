{
  "extends": "@quasar/app-webpack/tsconfig-preset",
  "compilerOptions": {
    "paths": {
      "@shared/*": ["./src/shared/*"],
      "@entities/*": ["./src/entities/*"],
      "@features/*": ["./src/features/*"],
      "@widgets/*": ["./src/widgets/*"],
      "@pages/*": ["./src/pages/*"],
      "@app/*": ["./src/app/*"],
      "@fonts/*": ["./src/app/styles/fonts/*"]
    },

    "baseUrl": ".",
    "moduleResolution": "node", 
    "ignoreDeprecations": "6.0", 
  },
  "exclude": ["./config"],
  "ts-node": {
    "compilerOptions": {
      "module": "CommonJS",
      "resolveJsonModule": true
    }
  }
}